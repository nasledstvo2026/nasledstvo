<svg xmlns="http://www.w3.org/2000/svg" width="800" height="400" viewBox="0 0 800 400">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a0a0a"/>
      <stop offset="50%" style="stop-color:#2a1010"/>
      <stop offset="100%" style="stop-color:#0d1117"/>
    </linearGradient>
    <linearGradient id="glow1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ff5050;stop-opacity:0.3"/>
      <stop offset="100%" style="stop-color:#c82828;stop-opacity:0"/>
    </linearGradient>
    <linearGradient id="glow2" x1="100%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#bc8cff;stop-opacity:0.2"/>
      <stop offset="100%" style="stop-color:#ff5050;stop-opacity:0"/>
    </linearGradient>
  </defs>
  <rect width="800" height="400" fill="url(#bg)"/>
  <rect width="400" height="400" fill="url(#glow1)"/>
  <rect x="200" y="0" width="400" height="400" fill="url(#glow2)"/>
  <!-- Grid lines -->
  <g stroke="rgba(255,255,255,0.03)" stroke-width="1">
    <line x1="0" y1="100" x2="800" y2="100"/>
    <line x1="0" y1="200" x2="800" y2="200"/>
    <line x1="0" y1="300" x2="800" y2="300"/>
    <line x1="200" y1="0" x2="200" y2="400"/>
    <line x1="400" y1="0" x2="400" y2="400"/>
    <line x1="600" y1="0" x2="600" y2="400"/>
  </g>
  <!-- Nodes -->
  <g fill="none" stroke="rgba(255,80,80,0.3)" stroke-width="1.5">
    <circle cx="400" cy="100" r="30"/>
    <circle cx="280" cy="250" r="20"/>
    <circle cx="520" cy="250" r="20"/>
    <circle cx="200" cy="350" r="15"/>
    <circle cx="400" cy="350" r="15"/>
    <circle cx="600" cy="350" r="15"/>
  </g>
  <!-- Lines between nodes -->
  <g stroke="rgba(255,80,80,0.12)" stroke-width="1">
    <line x1="400" y1="130" x2="280" y2="230"/>
    <line x1="400" y1="130" x2="520" y2="230"/>
    <line x1="280" y1="270" x2="200" y2="335"/>
    <line x1="280" y1="270" x2="400" y2="335"/>
    <line x1="520" y1="270" x2="400" y2="335"/>
    <line x1="520" y1="270" x2="600" y2="335"/>
  </g>
</svg>
